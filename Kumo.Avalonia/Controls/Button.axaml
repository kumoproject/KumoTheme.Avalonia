    -->
    <!--  DisabledVisual Should be handled by the control, not the animated icon.  -->
    <!--
                    <Setter Target="ContentPresenter.(controls:AnimatedIcon.State)" Value="Normal" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
          </ContentPresenter>
        </ControlTemplate>
      </Setter.Value>
    </Setter>-->
  </ControlTheme>
</ResourceDictionary>
